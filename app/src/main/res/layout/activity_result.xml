<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blush_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Celebration emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="56sp"
            android:layout_marginBottom="8dp" />

        <!-- Congratulations title -->
        <TextView
            style="@style/AppTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/congratulations" />

        <!-- Score result card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/soft_peach">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvGameType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Game: Memory Match"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_purple" />

                <TextView
                    android:id="@+id/tvDifficulty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Difficulty: Easy"
                    android:textSize="16sp"
                    android:textColor="@color/pink_dark"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time: 00:00"
                    android:textSize="16sp"
                    android:textColor="@color/pink_dark"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvMovesResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moves: 0"
                    android:textSize="16sp"
                    android:textColor="@color/pink_dark"
                    android:layout_marginTop="10dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save score button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveScore"
            style="@style/AppPrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="💾  Save Score"
            app:cornerRadius="28dp"
            android:layout_marginTop="24dp" />

        <!-- Share button - implicit intent (ACTION_SEND) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShare"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="📤  Share Score"
            style="@style/Widget.Material3.Button.TonalButton"
            app:cornerRadius="28dp"
            android:layout_marginTop="10dp" />

        <!-- Play Again and Home buttons side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayAgain"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:text="🔄 Play Again"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="28dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHome"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:text="🏠 Home"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="28dp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
