<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/blush_background">

    <!-- App logo with pink background -->
    <ImageView
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_launcher_foreground"
        android:background="@color/pink_primary"
        android:contentDescription="App Logo" />

    <!-- App name with heart -->
    <TextView
        style="@style/AppTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💗 Puzzle Hub"
        android:layout_marginTop="16dp" />

    <!-- Version -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Version 1.0  ✨"
        android:textSize="14sp"
        android:textColor="@color/pink_primary"
        android:layout_marginTop="6dp" />

    <!-- Pink divider line -->
    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:background="@color/pink_primary"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp" />

    <!-- App description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A fun mini-game hub featuring Memory Match Cards and Sliding Number Puzzle. Challenge yourself and track your scores! 💖"
        android:textSize="16sp"
        android:textColor="@color/pink_dark"
        android:textAlignment="center"
        android:lineSpacingMultiplier="1.4" />

    <!-- Developer credit -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Developed by: Student Developer 👩‍💻"
        android:textSize="15sp"
        android:textStyle="italic"
        android:textColor="@color/accent_purple"
        android:layout_marginTop="24dp" />

    <!-- Open project link button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenProject"
        style="@style/AppPrimaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌐  Open Project Page"
        app:cornerRadius="28dp"
        android:layout_marginTop="32dp" />

</LinearLayout>
